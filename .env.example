# Fireworks API Configuration
FIREWORKS_API_KEY=fw_your_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# HuggingFace Configuration (For Local Model Download)
HF_TOKEN=hf_your_token_here
MODEL_NAME=google/gemma-3-12b-it

# Local Model Server Link (Auto-configured in docker-compose.yml)
LOCAL_MODEL_URL=http://local-model-server:8000

# Tuning Thresholds
HIGH_CONFIDENCE_THRESHOLD=0.85
MEDIUM_CONFIDENCE_THRESHOLD=0.60

# Telemetry & Optimization
ENABLE_CACHE=true
LOG_LEVEL=info

# Docker Build Customization for Local Model Server (lightweight/serverless vs GPU/ROCm)
# By default, LOCAL_MODEL_BASE_IMAGE is python:3.10-slim and INSTALL_HEAVY is false (saves ~15GB+ space)
# For GPU/ROCm build, set:
# LOCAL_MODEL_BASE_IMAGE=rocm/pytorch:rocm6.1_ubuntu22.04_py3.10_pytorch_2.4
# INSTALL_HEAVY=true
LOCAL_MODEL_BASE_IMAGE=python:3.10-slim
INSTALL_HEAVY=false

